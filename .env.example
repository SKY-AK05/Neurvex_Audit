# Database Settings
PGHOST=your-database-host.postgres.database.azure.com
PGPORT=5432
PGDATABASE=nd_audit
PGUSER=your-database-username
PGPASSWORD=your-database-password

# Microsoft Entra ID (admin portal sign-in; also served at GET /api/auth/config)
ENTRA_CLIENT_ID=your-azure-ad-application-client-id
ENTRA_TENANT_ID=your-azure-ad-tenant-id

# Azure Communication Services (Email) Settings
ACS_CONNECTION_STRING=endpoint=https://your-acs-resource-name.unitedstates.communication.azure.com/;accesskey=your-acs-access-key
ACS_SENDER_ADDRESS=your-sender@your-domain.com
ACS_SENDER_NAME=Your Sender Display Name

# JWT Authentication Settings
JWT_SECRET=your-jwt-secret-signing-key

# App Settings
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,https://niwi.orchvate.in
FRONTEND_URL=https://niwi.orchvate.in

# Optional: bake MSAL into the image at build (docker compose build). If empty, ENTRA_* above is enough at runtime.
# VITE_MSAL_CLIENT_ID=
# VITE_MSAL_TENANT_ID=
